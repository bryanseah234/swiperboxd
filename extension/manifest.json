{
  "manifest_version": 3,
  "name": "Swiperboxd Sync",
  "description": "Sync your Letterboxd watchlist and diary into Swiperboxd using your own browser session.",
  "version": "0.1.0",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": ["cookies", "storage", "alarms"],
  "host_permissions": [
    "https://letterboxd.com/*",
    "https://*.letterboxd.com/*",
    "https://swiperboxd.vercel.app/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://swiperboxd.vercel.app/*",
        "http://localhost/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
