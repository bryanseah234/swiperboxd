{
  "manifest_version": 3,
  "name": "Swiperboxd Sync",
  "description": "Sync your Letterboxd watchlist and diary into Swiperboxd using your own browser session.",
  "version": "0.1.0",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["cookies", "storage", "alarms"],
  "host_permissions": [
    "https://letterboxd.com/*",
    "https://*.letterboxd.com/*",
    "https://swiperboxd.vercel.app/*",
    "https://swiperboxd.hong-yi.me/*",
    "http://localhost/*",
    "http://localhost:8000/*",
    "http://127.0.0.1/*",
    "http://127.0.0.1:8000/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://swiperboxd.vercel.app/*",
        "https://swiperboxd.hong-yi.me/*",
        "http://localhost/*",
        "http://localhost:8000/*",
        "http://127.0.0.1/*",
        "http://127.0.0.1:8000/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://letterboxd.com/*",
        "https://*.letterboxd.com/*"
      ],
      "js": ["letterboxd-content.js"],
      "run_at": "document_idle"
    }
  ]
}
