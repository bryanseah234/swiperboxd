{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/refresh-lists",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/sync-users",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/backfill-scrapes",
      "schedule": "30 3 * * *"
    }
  ]
}
