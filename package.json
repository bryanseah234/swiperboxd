{
  "name": "codebase-skeleton",
  "private": true,
  "version": "0.2.0",
  "description": "Runnable discovery app baseline",
  "type": "module",
  "scripts": {
    "bootstrap:check": "node -e \"console.log('bootstrap check ok')\"",
    "lint": "python -m compileall src",
    "test:web": "node --test tests/web_state.test.js",
    "test:api": "pytest -q",
    "test": "npm run test:web && npm run test:api",
    "start": "uvicorn src.api.app:app --host 0.0.0.0 --port 8000"
  }
}
